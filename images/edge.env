# integration-sandbox image manifest — edge
#
# Same as default, but every OpenCHAMI service tracks :main / :edge so a single
# `make ci IMAGES=edge` exercises the freshest published builds.
# Override individual services as needed (SBX_<NAME>_IMAGE=...).

SBX_VAULT_IMAGE=hashicorp/vault:1.21
SBX_LOCALSTACK_IMAGE=localstack/localstack:3
SBX_POSTGRES_IMAGE=postgres:16-alpine

SBX_SUSHY_IMAGE=quay.io/metal3-io/sushy-tools:latest
SBX_IPMI_SIM_IMAGE=openchami/ipmi-sim:dev

SBX_SMD_IMAGE=ghcr.io/openchami/smd:latest
SBX_TOKENSMITH_IMAGE=ghcr.io/openchami/tokensmith:main
SBX_BOOT_IMAGE=ghcr.io/openchami/boot-service:main
SBX_METADATA_IMAGE=ghcr.io/openchami/metadata-service:main
SBX_FRU_IMAGE=ghcr.io/openchami/fru-tracker:main
SBX_POWER_IMAGE=ghcr.io/openchami/power-control:main
SBX_MAGELLAN_IMAGE=ghcr.io/openchami/magellan:main
